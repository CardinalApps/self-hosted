+ * separating them with a dot.
+ * 
+ *    {Component}.{Action}
+ * 
+ * The Component must be defined in the Components type, and the Action can be
+ * any arbitrary string except an asterisk (*).
+ */
 export const Capabilities = [
   /**
    * Users
@@ -45,4 +63,106 @@ export const Capabilities = [
