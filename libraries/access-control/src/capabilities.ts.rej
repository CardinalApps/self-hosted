 ] as const
 
+/**
+ * A type that includes all capabilities.
+ */
 export type CapabilitityString = typeof Capabilities[number]
+
+/**
+ * Capability Assignments are stored as an array of capability strings. The
+ * strings can be exact matching capabilities, or can use of a wildcard for
+ * selecting broader ranges of capabilities.
+ * 
+ *    `*.*` - Matches all components and all actions, granting all current and
+ *    future capabilities. Reserved for Owner account.
+ * 
+ *    `MusicApp.*` - Matches all actions in the MusicApp component, granting all
+ *    current and future MusicApp capabilities.
+ * 
+ *    `*.Login` - Matches only Login actions on all current and future
+ *    components.
+ */
+export type CapabilityAssignment =
+  CapabilitityString
+  | '*.*'
+  | `${Components}.*`
+  | `*.${string}`
+
+export type CapabilityAssignments = CapabilityAssignment[]
+
+/**
+ * Validate the syntax of an capability assignment.
+ */
+const validateCapabilitySyntax = (assignment: CapabilityAssignment): boolean => {
+  if (typeof assignment !== 'string') {
+    return false
+  }
+
+  if (!assignment.includes('.')) {
+    return false
+  }
+
+  const parts = assignment.split('.')
+
+  if (parts.length !== 2) {
+    return false
+  }
+
+  return true
+}
+
+/**
+ * Validate the syntax of an array of capability assignments.
+ */
+const validateCapabilitiesSyntax = (capabilityList: CapabilitityString[]): boolean => {
+  let allAreValid = true
+
+  for (const capability of capabilityList) {
+    if (!validateCapabilitySyntax(capability)) {
+      allAreValid = false
+    }
+  }
+
+  return allAreValid
+}
+
+/**
+ * Checks whether the capability assignment exists in the list of capabilities.
+ */
+export function hasCapability(assignment: CapabilityAssignment, capabilityList: CapabilitityString[]) {
+  if (!validateCapabilitySyntax(assignment)) {
+    return false
+  }
+
+  if (!validateCapabilitiesSyntax(capabilityList)) {
+    return false
+  }
+
+  const [assignmentComponent, assignmentAction] = assignment.split('.')
+
+  for (const capabilityToCheckAgainst of capabilityList) {
+    const [componentToCheckAgainst, actionToCheckAgainst] = capabilityToCheckAgainst.split('.')
+    let componetIsValid = false
+    let actionIsValid = false
+
+    if (
+      assignmentComponent === componentToCheckAgainst
+      || assignmentComponent === '*'
+    ) {
+      componetIsValid = true
+    }
+
+    if (
+      assignmentAction === actionToCheckAgainst
+      || assignmentAction === '*'
+    ) {
+      actionIsValid = true
+    }
+
+    if (componetIsValid && actionIsValid) {
+      return true
+    }
+  }
+
+  return false
+}
