-  ...DefaultGuestCapabilities,
-} as const
+export class AC {
+  // either the role or a caps list is needed
+  constructor(user: UserDuck) {
+    if (!user.role && !user?.capabilities?.length) {
+      this.capabilities = []
+    } else {
+      this.user = user
+
+      // use given caps, or load default caps for the role
+      if (user?.capabilities?.length) {
+        this.capabilities = user.capabilities
+      } else if (Object.values(Role).includes(user.role as Role)) {
+        this.capabilities = DefaultCapabilities[user.role as Role]
+      }
+    }
+  }
+
+  user: UserDuck
+  capabilities: CapabilitiesAssignment
+
+  can(cap: Capability) {
+    return this.capabilities.includes(cap)
+  }
+}
