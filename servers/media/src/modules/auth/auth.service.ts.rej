+  /**
+   * Checks whether a user has the capability needed to log into an app.
+   */
+  canUserLogin(user: User, app): boolean {
+    let requiredCapability: NamedCapability
+
+    switch (app) {
+      case CardinalApp.ADMIN:
+        requiredCapability = 'AdminApp.Login'
+        break
+      case CardinalApp.MUSIC:
+        requiredCapability = 'MusicApp.Login'
+        break
+      case CardinalApp.PHOTOS:
+        requiredCapability = 'PhotosApp.Login'
+        break
+      case CardinalApp.CINEMA:
+        requiredCapability = 'CinemaApp.Login'
+        break
+    }
+
+    if (!requiredCapability) {
+      throw new Error(`Login failed, could not determine which app the user is trying to log into, got: ${app}`)
+    }
+
+    if (hasCapability(requiredCapability, user.roles?.flatMap((role) => getRole(role.role as RoleName).capabilities))) {
+      return true
+    } else {
+      return false
+    }
+  }
