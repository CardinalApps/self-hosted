+
+  /**
+   * Revokes roles. If the user does not have the role, this quietly continues.
+   * Returns an array of the deleted assignments.
+   */
+  async revokeRoles(user: User, roles: RoleNames[] = []): Promise<RoleAssignment[]> {
+    const toRevoke: RoleAssignment[] = []
+
+    for (const role of roles) {
+      const assignment = await this.hasRole(user, role)
+
+      if (assignment) {
+        toRevoke.push(assignment)
+      }
+    }
+
+    try {
+      const deleted = await this.roleAssignmentRepository.remove(toRevoke)
+      return deleted
+    } catch (error) {
+      Logger.error(error)
+    }
+
+    throw new InternalServerErrorException()
+  }
 }
